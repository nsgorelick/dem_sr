{
  "description": "plan07 ssl encoder pretraining then supervised finetune full/full",
  "shared": {
    "data_root": "/data/training",
    "batch_size": 32,
    "workers": 3,
    "amp": true,
    "arch": "film_unet"
  },
  "pretrain": {
    "manifest": "experiment-runs/manifests/fraction1/train_non_au_full.txt",
    "max_patches": null,
    "epochs": 2,
    "lr": 0.0001,
    "mask_ratio_dem": 0.4,
    "mask_ratio_ae": 0.4,
    "augment_rotflip": true,
    "checkpoint_out": "experiment-runs/full/self_supervised_pretraining/checkpoints/ssl_encoder_pretrain.pt",
    "output_json": "experiment-runs/full/self_supervised_pretraining/pretrain_report.json"
  },
  "train": {
    "experiment": "baseline",
    "preset": "baseline",
    "seed": 42,
    "manifest": "experiment-runs/manifests/fraction1/train_non_au_full.txt",
    "max_patches": null,
    "epochs": 6,
    "lr": 0.0001,
    "checkpoint_out": "experiment-runs/full/self_supervised_pretraining/checkpoints/finetune_film_unet_6ep.pt",
    "output_json": "experiment-runs/full/self_supervised_pretraining/train_report.json",
    "resume": null,
    "pretrained_encoder_checkpoint": "experiment-runs/full/self_supervised_pretraining/checkpoints/ssl_encoder_pretrain.pt",
    "loss_system": "preset",
    "loss_preset": "baseline",
    "lambda_elev": 1.0,
    "lambda_slope": 0.5,
    "lambda_grad": 0.25,
    "lambda_curv": 0.1,
    "lambda_ms": 0.5,
    "lambda_sdf": 0.5,
    "lambda_contour": 0.25,
    "guidance_dropout": 0.3,
    "augment_rotflip": true
  },
  "eval": {
    "experiment": "baseline",
    "preset": "baseline",
    "prediction_source": [
      "model"
    ],
    "checkpoint": "experiment-runs/full/self_supervised_pretraining/checkpoints/finetune_film_unet_6ep.pt",
    "manifest": "experiment-runs/manifests/fraction1/val_au_full.txt",
    "list_from_root": false,
    "max_patches": null,
    "output_json": null,
    "per_patch_json": "experiment-runs/full/self_supervised_pretraining/eval_per_patch.json",
    "patch_table": "200k.geojson",
    "stratified_json": "experiment-runs/full/self_supervised_pretraining/eval_stratified.json"
  }
}
